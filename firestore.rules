// ============================================================
// Firestore Security Rules — cada utilizador só acede às SUAS cartas
// ------------------------------------------------------------
// Onde colar:
//   Firebase Console → Firestore Database → separador "Rules" → Publish
// (ou faz deploy com: firebase deploy --only firestore:rules)
//
// Modelo: users/{uid}/cards/{cardId} — uma "document" por carta.
//
// App de um só dono: só a conta abaixo pode ler/escrever. Muda o
// email se o dono mudar (tem de bater certo com window.ALLOWED_EMAIL
// no config.js).
// ============================================================
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Só a conta autorizada acede — e apenas debaixo do seu próprio uid.
    match /users/{userId}/cards/{cardId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && request.auth.token.email_verified == true
                         && request.auth.token.email == 'nunomcfrancisco@gmail.com';
    }

    // Tudo o resto fica bloqueado por omissão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
