// ============================================================
// Firestore Security Rules — each user only accesses THEIR OWN cards
// ------------------------------------------------------------
// Where to paste:
//   Firebase Console → Firestore Database → "Rules" tab → Publish
// (or deploy with: firebase deploy --only firestore:rules)
//
// Model: users/{uid}/cards/{cardId} — one document per card.
//
// Single-owner app: only the account below can read/write. Change the
// email if the owner changes (it must match window.ALLOWED_EMAIL
// in config.js).
// ============================================================
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only the authorized account has access — and only under its own uid.
    match /users/{userId}/cards/{cardId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && request.auth.token.email_verified == true
                         && request.auth.token.email == 'nunomcfrancisco@gmail.com';
    }

    // Everything else is blocked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
